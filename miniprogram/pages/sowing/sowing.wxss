/* pages/sowing/sowing.wxss */

.container {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  overflow: hidden;
}

/* 背景光晕 */
.bg-glow {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  height: 600rpx;
  background: radial-gradient(circle, rgba(74, 108, 111, 0.05) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

/* 莲花背景 */
.lotus-bg {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 400rpx;
  height: 400rpx;
  opacity: 0.06;
  pointer-events: none;
}

.lotus-image {
  width: 100%;
  height: 100%;
}

/* 主内容 */
.main-content {
  position: relative;
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  max-width: 600rpx;
}

/* 标题 */
.title-wrapper {
  margin-bottom: 80rpx;
}

.title {
  font-size: 54rpx;
  letter-spacing: 24rpx;
  color: var(--primary);
}

/* 输入框 */
.input-area {
  width: 100%;
  min-height: 120rpx;
  padding: 30rpx;
  text-align: center;
  font-size: 32rpx;
  letter-spacing: 4rpx;
  color: var(--text-primary);
  background: transparent;
  border-bottom: 2rpx solid rgba(74, 108, 111, 0.2);
  margin-bottom: 60rpx;
}

.input-placeholder {
  color: var(--text-hint);
}

/* 按钮 */
.btn-primary {
  margin-top: 40rpx;
  background-color: var(--primary);
  color: white;
  border-radius: 100rpx;
  padding: 28rpx 80rpx;
  font-size: 30rpx;
  letter-spacing: 10rpx;
  box-shadow: 0 4rpx 20rpx rgba(74, 108, 111, 0.2);
  border: none;
}

.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-disabled {
  opacity: 0.4;
}

/* 提示文字 */
.hint-text {
  margin-top: 40rpx;
  font-size: 24rpx;
  color: var(--text-hint);
  letter-spacing: 4rpx;
  text-align: center;
}

/* 播种动画 */
.seed-animation {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}

.seed-animation.show {
  opacity: 1;
}

.seed-dot {
  width: 16rpx;
  height: 16rpx;
  background-color: var(--primary);
  border-radius: 50%;
  box-shadow: 0 0 60rpx 20rpx rgba(74, 108, 111, 0.4);
  animation: seedPulse 2s ease-in-out forwards;
}

@keyframes seedPulse {
  0% { transform: scale(1); opacity: 1; }
  100% { transform: scale(0); opacity: 0; }
}

/* 图鉴按钮 */
.gallery-btn {
  position: absolute;
  bottom: 80rpx;
  left: 50%;
  transform: translateX(-50%);
}

.btn-secondary {
  background-color: rgba(74, 108, 111, 0.05);
  color: var(--text-secondary);
  border-radius: 100rpx;
  padding: 20rpx 40rpx;
  font-size: 26rpx;
  letter-spacing: 6rpx;
}
