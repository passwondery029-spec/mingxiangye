/* pages/incubation/incubation.wxss */

.container {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

/* 纸质纹理 */
.paper-texture {
  position: absolute;
  inset: 0;
  background-image: url('https://www.transparenttextures.com/patterns/rice-paper.png');
  opacity: 0.2;
  pointer-events: none;
}

/* 水波纹容器 */
.ripple-container {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.ripple {
  position: absolute;
  border-radius: 50%;
  border: 4rpx solid rgba(74, 108, 111, 0.4);
  animation: rippleExpand 12s ease-out infinite;
}

.ripple-1 { animation-delay: 0s; }
.ripple-2 { animation-delay: 4s; }
.ripple-3 { animation-delay: 8s; }

@keyframes rippleExpand {
  0% {
    width: 100rpx;
    height: 100rpx;
    opacity: 0.8;
    border-width: 4rpx;
  }
  100% {
    width: 2000rpx;
    height: 2000rpx;
    opacity: 0;
    border-width: 1rpx;
  }
}

/* 呼吸光晕 */
.breathing-glow {
  position: absolute;
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(74, 108, 111, 0.2) 0%, transparent 70%);
  transition: all 4s ease-in-out;
}

.breathing-glow.inhale {
  transform: scale(1.2);
  opacity: 0.8;
}

.breathing-glow.exhale {
  transform: scale(1);
  opacity: 0.4;
}

/* 主内容 */
.main-content {
  position: relative;
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 呼吸文字 */
.breath-text {
  font-size: 48rpx;
  letter-spacing: 20rpx;
  color: var(--text-primary);
  animation: breathFade 4s ease-in-out infinite;
}

@keyframes breathFade {
  0%, 100% { opacity: 0.8; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.05); }
}

/* 计时器 */
.timer {
  margin-top: 40rpx;
  font-size: 28rpx;
  letter-spacing: 8rpx;
  color: var(--text-hint);
  font-family: 'SF Mono', 'Monaco', monospace;
}

/* 跳过按钮 */
.skip-btn {
  position: absolute;
  bottom: 80rpx;
  left: 50%;
  transform: translateX(-50%);
  padding: 20rpx 40rpx;
  background-color: rgba(74, 108, 111, 0.05);
  border-radius: 100rpx;
}

.skip-text {
  font-size: 24rpx;
  letter-spacing: 4rpx;
  color: var(--text-hint);
}
